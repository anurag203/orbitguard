{
  "name": "orbitguard-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:website": "npm run test:e2e",
    "smoke": "node e2e/smoke.mjs",
    "smoke:live": "node ../scripts/smoke-live.mjs",
    "size": "node scripts/check-bundle-size.mjs",
    "lhci": "npx @lhci/cli@0.15.1 autorun"
  },
